# ===================================================
# SellsHRMS Environment Configuration Example
# Copy this file to `.env` and modify values
# ===================================================

# Spring profile
SPRING_PROFILES_ACTIVE=local

# ---------------------------------------------------
# Application Settings
# ---------------------------------------------------
SERVER_PORT=8080
APP_BASE_URL=http://localhost:8080

# Upload folder
# Windows example: C:/uploads/hrms-files
# Mac/Linux example: /opt/hrms/uploads
UPLOAD_BASE_DIR=/opt/hrms/uploads

# .env file for production
SUPER_ADMIN_EMAIL=admin@sellspark.in
SUPER_ADMIN_PASSWORD=admin@123

# ---------------------------------------------------
# Database (Spring Boot)
# ---------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=SellsHRMS
DB_USER=hrmsuser
DB_PASSWORD=change_this_password

# Hibernate strategy
HIBERNATE_DDL_AUTO=update

# ---------------------------------------------------
# Async Thread Pool
# ---------------------------------------------------
ASYNC_CORE_SIZE=4
ASYNC_MAX_SIZE=10
ASYNC_QUEUE_CAPACITY=50

# ---------------------------------------------------
# MySQL Docker Initialization
# ---------------------------------------------------
MYSQL_ROOT_PASSWORD=change_root_password
MYSQL_DATABASE=SellsHRMS
MYSQL_USER=hrmsuser
MYSQL_PASSWORD=change_user_password